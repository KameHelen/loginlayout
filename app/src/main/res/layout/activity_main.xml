<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0D0D15"
    android:padding="24dp">

    <!-- Logo -->
    <ImageView
        android:id="@+id/imageViewLogo"
        android:layout_width="200dp"
        android:layout_height="160dp"
        android:src="@drawable/logo_ukey"
        android:contentDescription="Logo U-KEY"
        android:layout_marginBottom="36dp" />

    <!-- Campo Login -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:hintTextColor="#A020F0"
        app:boxStrokeColor="#A020F0"
        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Login"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:inputType="text"
            android:backgroundTint="#0D0D15" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Campo Password -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:hintTextColor="#A020F0"
        app:boxStrokeColor="#A020F0"
        app:boxStrokeWidth="2dp"
        app:boxStrokeWidthFocused="3dp"
        app:passwordToggleEnabled="true"
        app:passwordToggleDrawable="@drawable/ic_eye">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/editTextPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:inputType="textPassword"
            android:backgroundTint="#0D0D15" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botón Inicio de Sesión -->
    <Button
        android:id="@+id/buttonLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Inicio de sesión"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/btn_neon_purple"
        android:elevation="4dp" />

</LinearLayout>